<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TEKLauncher.Avalonia.Views.WhatsNewWindow"
        xmlns:u="clr-namespace:TEKLauncher.UI"
        Width="820"
        Height="620"
        MinWidth="420"
        MinHeight="280"
        Title="{u:Tr whatsNew}">
  <Border Margin="16" Padding="12" CornerRadius="12" Background="#10233A" BorderBrush="#2E5E8C" BorderThickness="1">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel x:Name="Root" Spacing="10" />
    </ScrollViewer>
  </Border>
</Window>