<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ObeliskLauncher.Avalonia.Views.FatalErrorWindow"
        xmlns:u="clr-namespace:ObeliskLauncher.UI"
        Width="760"
        Height="720"
        MinWidth="560"
        MinHeight="420"
        Title="{u:Tr fatalErrorWindow.title}">
  <Border Margin="16" Padding="18" CornerRadius="12" Background="#10233A" BorderBrush="#2E5E8C" BorderThickness="1">
    <Grid RowDefinitions="Auto,*">
      <Grid ColumnDefinitions="Auto,*">
        <Border Width="120" Height="120" CornerRadius="60" Background="#9E2313" VerticalAlignment="Center">
          <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="56" FontWeight="Bold" Text="!" />
        </Border>
        <StackPanel Grid.Column="1" Margin="18,0,0,0" Spacing="10" VerticalAlignment="Center">
          <TextBlock x:Name="FatalMessageText" TextWrapping="Wrap" />
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Content="{u:Tr mainWindow.openDiscord}" Click="OpenDiscord" HorizontalAlignment="Left" />
            <Button x:Name="CopyErrorButton" Content="{u:Tr mainWindow.copyError}" Click="CopyError" HorizontalAlignment="Left" />
          </StackPanel>
        </StackPanel>
      </Grid>
      <Border Grid.Row="1" Margin="0,16,0,0" Padding="10" CornerRadius="10" Background="#D021252B">
        <TextBox x:Name="ExceptionData"
                 FontSize="15"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 BorderThickness="0"
                 Background="Transparent" />
      </Border>
    </Grid>
  </Border>
</Window>