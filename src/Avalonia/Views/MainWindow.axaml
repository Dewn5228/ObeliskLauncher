<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ObeliskLauncher.Avalonia.Views.MainWindow"
        xmlns:vm="clr-namespace:ObeliskLauncher.Avalonia.ViewModels"
        xmlns:d="clr-namespace:ObeliskLauncher.Data"
        xmlns:p="clr-namespace:ObeliskLauncher.Platform"
        xmlns:u="clr-namespace:ObeliskLauncher.UI"
        xmlns:v="clr-namespace:ObeliskLauncher.Avalonia.Views"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="True"
        Width="1100"
        Height="720"
        MinWidth="900"
        MinHeight="600"
        Title="Obelisk Launcher">
  <Window.DataTemplates>
    <DataTemplate DataType="vm:PlaySectionScreenViewModel">
      <StackPanel Spacing="16">
        <Border Padding="8" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1" IsVisible="{Binding HasHeroImage}">
          <Image Source="{Binding HeroImagePath}" Stretch="UniformToFill" Height="220" />
        </Border>
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1">
          <StackPanel Spacing="10">
            <TextBlock Text="{u:Tr playTab.currentGamePath}" FontWeight="SemiBold" />
            <TextBlock Text="{Binding CurrentGamePath}" TextWrapping="Wrap" />
            <TextBlock Text="{Binding LaunchBehaviorNote}" IsVisible="{Binding LaunchBehaviorNoteVisible}" Opacity="0.78" TextWrapping="Wrap" />
            <CheckBox Content="{u:Tr mainWindow.runGameAsAdmin}" IsChecked="{Binding RunAsAdmin}" IsVisible="{Binding RunAsAdminVisible}" />
            <CheckBox Content="{u:Tr mainWindow.useSpacewar}" IsChecked="{Binding UseSpacewar}" IsVisible="{Binding UseSpacewarVisible}" />
          </StackPanel>
        </Border>
        <Grid ColumnDefinitions="*,*">
          <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1">
            <StackPanel Spacing="10">
              <TextBlock Text="{u:Tr playTab.gameLanguage}" FontWeight="SemiBold" />
              <ComboBox SelectedIndex="{Binding GameLanguageIndex}" SelectionChanged="GameLanguageChanged" ItemsSource="{Binding GameLanguages}" />
            </StackPanel>
          </Border>
          <Border Grid.Column="1" Margin="16,0,0,0" Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1">
            <StackPanel Spacing="10">
              <TextBlock Text="{u:Tr playTab.launcherLanguage}" FontWeight="SemiBold" />
              <ComboBox SelectedIndex="{Binding LauncherLanguageIndex}" SelectionChanged="LauncherLanguageChanged" ItemsSource="{Binding LauncherLanguages}" IsEnabled="{Binding LauncherLanguageSelectionEnabled}" />
              <TextBlock Text="{Binding LauncherLanguageAvailabilityNote}" IsVisible="{Binding LauncherLanguageAvailabilityNoteVisible}" Opacity="0.78" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </Grid>
        <Button HorizontalAlignment="Left" MinWidth="180" Content="{Binding PlayButtonText}" Click="LaunchGame" />
      </StackPanel>
    </DataTemplate>
    <DataTemplate DataType="vm:AboutSectionScreenViewModel">
      <StackPanel Spacing="16">
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1">
          <StackPanel Spacing="8">
            <TextBlock FontSize="22" FontWeight="SemiBold">
              <Run Text="{u:Tr version.launcherVersion}" />
              <Run Text=": " />
              <Run Text="{Binding AppVersion}" />
            </TextBlock>
            <TextBlock Text="{Binding DescriptionBody}" TextWrapping="Wrap" />
          </StackPanel>
        </Border>
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1">
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding KeyFeaturesHeader}" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="{Binding KeyFeaturesText}" TextWrapping="Wrap" />
          </StackPanel>
        </Border>
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1">
          <StackPanel Spacing="10">
            <TextBlock Text="{Binding LinksHeader}" FontSize="18" FontWeight="SemiBold" />
            <WrapPanel>
              <Button Content="{u:Tr mainWindow.license}" Click="OpenLicenseLink" />
              <Button Margin="10,0,0,0" Content="{u:Tr mainWindow.discord}" Click="OpenDiscordLink" />
              <Button Margin="10,0,0,0" Content="{u:Tr mainWindow.githubRepo}" Click="OpenRepoLink" />
            </WrapPanel>
          </StackPanel>
        </Border>
      </StackPanel>
    </DataTemplate>
    <DataTemplate DataType="vm:GameOptionsSectionScreenViewModel">
      <StackPanel Spacing="16">
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1">
          <StackPanel Spacing="8">
            <TextBlock Text="{u:Tr playTab.currentGamePath}" FontWeight="SemiBold" />
            <TextBlock Text="{Binding CurrentGamePath}" TextWrapping="Wrap" />
            <TextBlock Text="{Binding MaintenanceNote}" Opacity="0.78" TextWrapping="Wrap" />
            <Border Padding="12" CornerRadius="10" Background="#132132" BorderBrush="#2A4C6D" BorderThickness="1">
              <StackPanel Spacing="8">
                <TextBlock Text="{u:Tr mainWindow.installLocation}" FontWeight="SemiBold" />
                <TextBlock Text="{u:Tr mainWindow.toInstallArkOpenSettings}" Opacity="0.78" TextWrapping="Wrap" />
                <Button HorizontalAlignment="Left" Content="{u:Tr mainWindow.openLauncherSettings}" Click="OpenLauncherSettingsSection" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1" IsVisible="{Binding HasStatus}">
          <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" TextWrapping="Wrap" />
        </Border>
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1">
          <StackPanel Spacing="12">
            <TextBlock Text="{u:Tr mainWindow.maintenance}" FontSize="18" FontWeight="SemiBold" />
            <WrapPanel>
              <Button Content="{u:Tr mainWindow.update}" Click="UpdateBaseGame" IsEnabled="{Binding CanRunMaintenance}" />
              <Button Margin="10,0,0,0" Content="{u:Tr mainWindow.validate}" Click="ValidateBaseGame" IsEnabled="{Binding CanRunMaintenance}" />
              <Button Margin="10,0,0,0" Content="{u:Tr mainWindow.fixBloom}" Click="FixGameBloom" IsVisible="{Binding FixBloomAndSkinsVisible}" IsEnabled="{Binding CanRunMaintenance}" />
              <Button Margin="10,0,0,0" Content="{u:Tr mainWindow.unlockSkins}" Click="UnlockGameSkins" IsVisible="{Binding FixBloomAndSkinsVisible}" IsEnabled="{Binding CanRunMaintenance}" />
            </WrapPanel>
          </StackPanel>
        </Border>
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1">
          <StackPanel Spacing="10">
            <CheckBox Content="{u:Tr mainWindow.highProcessPriority}" IsChecked="{Binding HighProcessPriority}" IsVisible="{Binding HighProcessPriorityVisible}" />
            <TextBlock Text="{Binding HighProcessPriorityDescription}" IsVisible="{Binding HighProcessPriorityVisible}" Opacity="0.78" TextWrapping="Wrap" />
            <TextBlock Text="{u:Tr mainWindow.directXDetected}" IsVisible="{Binding DirectXInstalledVisible}" Foreground="#0AA63E" />
            <TextBlock Text="{u:Tr mainWindow.directXMissing}" IsVisible="{Binding DirectXMissingVisible}" Foreground="#D4573B" />
          </StackPanel>
        </Border>
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1">
          <StackPanel Spacing="12">
            <TextBlock Text="{u:Tr launchOptimization.launchParameters}" FontSize="18" FontWeight="SemiBold" IsVisible="{Binding PredefinedLaunchParametersVisible}" />
            <ItemsControl ItemsSource="{Binding LaunchParameters}" IsVisible="{Binding PredefinedLaunchParametersVisible}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:GameOptionsLaunchParameterViewModel">
                  <Border Padding="12" CornerRadius="12" Background="#132132" BorderBrush="#2A4C6D" BorderThickness="1">
                    <StackPanel Spacing="4">
                      <CheckBox Content="{Binding Title}" IsChecked="{Binding IsEnabled}" />
                      <TextBlock Margin="24,0,0,0" Text="{Binding Description}" Opacity="0.78" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="{u:Tr playTab.customLaunchParameters}" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,Auto">
              <TextBox Text="{Binding CustomLaunchParameters}" PlaceholderText="{u:Tr mainWindow.placeholderLaunchParams}" />
              <Button Grid.Column="1" Margin="12,0,0,0" Content="{u:Tr mainWindow.apply}" Click="ApplyGameOptionsCustomParameters" />
            </Grid>
          </StackPanel>
        </Border>
      </StackPanel>
    </DataTemplate>
    <DataTemplate DataType="vm:DlcSectionScreenViewModel">
      <StackPanel Spacing="16">
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1">
          <TextBlock Text="{Binding SectionNote}" Opacity="0.78" TextWrapping="Wrap" />
        </Border>
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1" IsVisible="{Binding HasStatus}">
          <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" TextWrapping="Wrap" />
        </Border>
        <ItemsControl ItemsSource="{Binding Rows}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="vm:DlcRowViewModel">
              <Border Padding="16" CornerRadius="12" Background="#132132" BorderBrush="#2A4C6D" BorderThickness="1">
                <StackPanel Spacing="10">
                  <StackPanel>
                    <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" />
                  </StackPanel>
                  <WrapPanel>
                    <Button Content="{u:Tr mainWindow.installUpdate}" Click="OpenDlcInstallUpdater" IsEnabled="{Binding CanInstall}" />
                    <Button Margin="10,0,0,0" Content="{u:Tr mainWindow.validate}" Click="OpenDlcValidator" IsEnabled="{Binding CanValidate}" />
                    <Button Margin="10,0,0,0" Content="{u:Tr mainWindow.delete}" Click="DeleteDlc" IsEnabled="{Binding CanDelete}" />
                  </WrapPanel>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </DataTemplate>
    <DataTemplate DataType="vm:ModsSectionScreenViewModel">
      <StackPanel Spacing="16">
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1">
          <StackPanel Spacing="10">
            <TextBlock Text="{u:Tr mainWindow.installModByWorkshopId}" FontSize="18" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,Auto,Auto">
              <TextBox Text="{Binding InstallIdInput}" PlaceholderText="{u:Tr mainWindow.workshopId}" />
              <Button Grid.Column="1" Margin="12,0,0,0" Content="{u:Tr mainWindow.lookup}" Click="LookupModInstallCandidate" />
              <Button Grid.Column="2" Margin="12,0,0,0" Content="{u:Tr mainWindow.install}" Click="InstallSelectedMod" IsEnabled="{Binding CanInstallSelected}" />
            </Grid>
            <Border Padding="12" CornerRadius="10" Background="#132132" BorderBrush="#2A4C6D" BorderThickness="1" IsVisible="{Binding HasCandidate}">
              <StackPanel Spacing="6">
                <TextBlock Text="{Binding CandidateTitle}" FontSize="16" FontWeight="SemiBold" />
                <TextBlock Text="{Binding CandidateSubtitle}" Opacity="0.72" />
                <Button HorizontalAlignment="Left" Content="{u:Tr mainWindow.openWorkshop}" Click="OpenSelectedWorkshopPage" IsEnabled="{Binding CanOpenSelectedWorkshop}" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1">
          <StackPanel Spacing="10">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
              <TextBox Text="{Binding WorkshopQuery}" PlaceholderText="{u:Tr mainWindow.searchWorkshopMods}" />
              <Button Grid.Column="1" Margin="12,0,0,0" Content="{u:Tr mainWindow.search}" Click="SearchWorkshopMods" />
              <Button Grid.Column="2" Margin="12,0,0,0" Content="{u:Tr mainWindow.reload}" Click="ReloadWorkshopMods" />
              <TextBlock Grid.Column="3" Margin="12,0,0,0" Text="{Binding WorkshopPageText}" VerticalAlignment="Center" />
            </Grid>
            <Border Padding="12" CornerRadius="10" Background="#132132" BorderBrush="#2A4C6D" BorderThickness="1" IsVisible="{Binding HasWorkshopStatus}">
              <TextBlock Text="{Binding WorkshopStatusText}" Foreground="#D4573B" TextWrapping="Wrap" />
            </Border>
            <ItemsControl ItemsSource="{Binding WorkshopRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:WorkshopModRowViewModel">
                  <Border Padding="14" CornerRadius="12" Background="#132132" BorderBrush="#2A4C6D" BorderThickness="1">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel>
                        <TextBlock Text="{Binding DisplayName}" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding DetailText}" Opacity="0.72" />
                        <TextBlock Text="{u:Tr common.installed}" IsVisible="{Binding IsInstalled}" Foreground="#0AA63E" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Content="{u:Tr mainWindow.workshop}" Click="OpenWorkshopResultPage" />
                        <Button Content="{u:Tr mainWindow.select}" Click="SelectWorkshopModResult" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <WrapPanel>
              <Button Content="{u:Tr mainWindow.previous}" Click="LoadPreviousWorkshopModsPage" IsEnabled="{Binding CanLoadPreviousWorkshopPage}" />
              <Button Margin="10,0,0,0" Content="{u:Tr mainWindow.next}" Click="LoadNextWorkshopModsPage" IsEnabled="{Binding CanLoadNextWorkshopPage}" />
            </WrapPanel>
          </StackPanel>
        </Border>
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1" IsVisible="{Binding HasStatus}">
          <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" TextWrapping="Wrap" />
        </Border>
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1" IsVisible="{Binding HasNoMods}">
          <TextBlock Text="{u:Tr mainWindow.noInstalledMods}" TextWrapping="Wrap" Opacity="0.82" />
        </Border>
        <ItemsControl ItemsSource="{Binding Rows}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="vm:ModRowViewModel">
              <Border Padding="16" CornerRadius="12" Background="#132132" BorderBrush="#2A4C6D" BorderThickness="1">
                <StackPanel Spacing="10">
                  <StackPanel>
                    <TextBlock Text="{Binding DisplayName}" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DetailText}" Opacity="0.72" />
                    <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" />
                  </StackPanel>
                  <WrapPanel>
                    <Button Content="{u:Tr mainWindow.copyId}" Click="CopyInstalledModId" />
                    <Button Margin="10,0,0,0" Content="{u:Tr mainWindow.workshop}" Click="OpenInstalledModWorkshopPage" />
                    <Button Margin="10,0,0,0" Content="{u:Tr mainWindow.update}" Click="UpdateInstalledMod" IsEnabled="{Binding CanUpdate}" />
                    <Button Margin="10,0,0,0" Content="{u:Tr mainWindow.validate}" Click="ValidateInstalledMod" IsEnabled="{Binding CanValidate}" />
                    <Button Margin="10,0,0,0" Content="{u:Tr mainWindow.delete}" Click="DeleteInstalledMod" IsEnabled="{Binding CanDelete}" />
                  </WrapPanel>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </DataTemplate>
    <DataTemplate DataType="vm:GlobalLauncherSettingsSectionScreenViewModel">
      <StackPanel Spacing="16">
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1">
          <StackPanel Spacing="10">
            <TextBlock Text="{u:Tr launcherSettingsTab.aseGamePath}" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,Auto">
              <TextBox Text="{Binding AseGamePath, UpdateSourceTrigger=PropertyChanged}" LostFocus="SettingsGamePathEdited" />
              <Button Grid.Column="1" Margin="12,0,0,0" Content="{u:Tr mainWindow.browse}" Click="BrowseSettingsAseGamePath" />
            </Grid>
            <TextBlock Text="{u:Tr launcherSettingsTab.asaGamePath}" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,Auto">
              <TextBox Text="{Binding AsaGamePath, UpdateSourceTrigger=PropertyChanged}" LostFocus="SettingsGamePathEdited" />
              <Button Grid.Column="1" Margin="12,0,0,0" Content="{u:Tr mainWindow.browse}" Click="BrowseSettingsAsaGamePath" />
            </Grid>
            <TextBlock Text="{u:Tr mainWindow.gamePathDescription}" Opacity="0.78" TextWrapping="Wrap" />
          </StackPanel>
        </Border>
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1">
          <StackPanel Spacing="10">
            <TextBlock Text="Global settings" FontWeight="SemiBold" FontSize="16" />
            <CheckBox Content="{u:Tr mainWindow.closeOnGameLaunch}" IsChecked="{Binding CloseOnGameLaunch}" IsCheckedChanged="SettingsCloseOnLaunchChanged" />
            <CheckBox Content="{u:Tr mainWindow.preAquaticaMode}" IsChecked="{Binding PreAquatica}" IsVisible="{Binding PreAquaticaVisible}" IsCheckedChanged="SettingsPreAquaticaChanged" />
          </StackPanel>
        </Border>
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1" IsVisible="{Binding LinuxLaunchPresetsVisible}">
          <StackPanel Spacing="6">
            <TextBlock Text="{u:Tr mainWindow.linuxLaunchPresets}" FontWeight="SemiBold" />
            <ComboBox ItemsSource="{Binding LinuxLaunchPresets}" SelectedItem="{Binding SelectedLinuxLaunchPreset}">
              <ComboBox.ItemTemplate>
                <DataTemplate DataType="d:LinuxLaunchPreset">
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
              <TextBox Text="{Binding LinuxLaunchPresetName, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="{u:Tr mainWindow.presetName}" />
              <Button Grid.Column="1" Margin="10,0,0,0" Content="{u:Tr mainWindow.savePreset}" Click="SaveLinuxLaunchPreset" />
              <Button Grid.Column="2" Margin="10,0,0,0" Content="{u:Tr mainWindow.applyPreset}" Click="ApplyLinuxLaunchPreset" IsEnabled="{Binding CanApplyLinuxLaunchPreset}" />
              <Button Grid.Column="3" Margin="10,0,0,0" Content="{u:Tr mainWindow.deletePreset}" Click="DeleteLinuxLaunchPreset" IsEnabled="{Binding CanDeleteLinuxLaunchPreset}" />
            </Grid>
          </StackPanel>
        </Border>
        <WrapPanel>
          <Button Content="{u:Tr mainWindow.applyGamePath}" Click="ApplySettingsGamePath" />
          <Button Margin="10,0,0,0" Content="{u:Tr mainWindow.cleanDownloadCache}" Click="CleanDownloadCache" />
          <Button Margin="10,0,0,0" Content="{u:Tr mainWindow.deleteLauncherSettings}" Click="DeleteLauncherSettings" />
        </WrapPanel>
      </StackPanel>
    </DataTemplate>

    <DataTemplate DataType="vm:AseLauncherSettingsSectionScreenViewModel">
      <StackPanel Spacing="16">
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1">
          <StackPanel Spacing="8">
            <TextBlock Text="ASE settings" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Text="{u:Tr mainWindow.linuxCompatibilityTool}" FontWeight="SemiBold" />
            <ComboBox ItemsSource="{Binding LinuxLaunchTools}" SelectedIndex="{Binding SelectedAseLinuxLaunchToolIndex, Mode=TwoWay}" SelectionChanged="AseLinuxLaunchToolChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate DataType="p:LinuxLaunchToolOption">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <WrapPanel>
              <Button Content="{u:Tr mainWindow.importProtonPath}" Click="ImportAseLinuxProtonTool" />
              <Button Margin="10,0,0,0" Content="{u:Tr mainWindow.importWinePath}" Click="ImportAseLinuxWineTool" />
            </WrapPanel>
            <TextBlock Text="{Binding LinuxLaunchToolNote}" TextWrapping="Wrap" Foreground="#A7C4E3" />
          </StackPanel>
        </Border>

        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1">
          <StackPanel Spacing="8">
            <TextBlock Text="{u:Tr mainWindow.customPrefix}" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,Auto">
              <TextBox Text="{Binding AseLinuxCustomPrefixPath, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="{u:Tr mainWindow.placeholderCustomPrefix}" />
              <Button Grid.Column="1" Margin="12,0,0,0" Content="{u:Tr mainWindow.browse}" Click="BrowseAseLinuxCompatPrefix" />
            </Grid>
            <TextBlock Text="{u:Tr mainWindow.customPrefixDescription}" Opacity="0.78" TextWrapping="Wrap" />

            <WrapPanel Margin="0,8,0,0">
              <CheckBox Content="{u:Tr mainWindow.gamemoderun}" IsChecked="{Binding AseLinuxUseGameMode}" />
              <CheckBox Margin="14,0,0,0" Content="{u:Tr mainWindow.gamescope}" IsChecked="{Binding AseLinuxUseGamescope}" />
              <CheckBox Margin="14,0,0,0" Content="{u:Tr mainWindow.mangohud}" IsChecked="{Binding AseLinuxUseMangoHud}" />
              <CheckBox Margin="14,0,0,0" Content="{u:Tr mainWindow.vkbasalt}" IsChecked="{Binding AseLinuxUseVkBasalt}" />
              <CheckBox Margin="14,0,0,0" Content="{u:Tr mainWindow.wineFsr}" IsChecked="{Binding AseLinuxUseWineFullscreenFsr}" />
            </WrapPanel>

            <StackPanel Spacing="6" IsVisible="{Binding AseLinuxGamescopeOptionsVisible}">
              <TextBlock Text="{u:Tr mainWindow.gamescopeArguments}" FontWeight="SemiBold" />
              <TextBox Text="{Binding AseLinuxGamescopeArguments, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="{u:Tr mainWindow.placeholderGamescopeArgs}" />
              <CheckBox Content="{u:Tr mainWindow.enableGamescopeFsr}" IsChecked="{Binding AseLinuxUseGamescopeFsr}" />
              <TextBox Text="{Binding AseLinuxGamescopeSharpness, UpdateSourceTrigger=PropertyChanged}" IsVisible="{Binding AseLinuxGamescopeFsrOptionsVisible}" PlaceholderText="{u:Tr mainWindow.gamescopeFsrSharpness}" />
            </StackPanel>

            <StackPanel Spacing="6" IsVisible="{Binding AseLinuxWineFsrOptionsVisible}">
              <TextBlock Text="{u:Tr mainWindow.wineFsrStrength}" FontWeight="SemiBold" />
              <TextBox Text="{Binding AseLinuxWineFullscreenFsrStrength, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="{u:Tr mainWindow.placeholderWineFsrStrength}" />
            </StackPanel>

            <TextBlock Margin="0,8,0,0" Text="{u:Tr mainWindow.extraEnvVars}" FontWeight="SemiBold" />
            <TextBox Text="{Binding AseLinuxExtraEnvironmentVariables, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90" PlaceholderText="{u:Tr mainWindow.placeholderExtraEnv}" />

            <TextBlock Margin="0,8,0,0" Text="{u:Tr mainWindow.launchWrappers}" FontWeight="SemiBold" />
            <TextBox Text="{Binding AseLinuxLaunchWrappers, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90" PlaceholderText="{u:Tr mainWindow.placeholderLaunchWrappers}" />
          </StackPanel>
        </Border>
      </StackPanel>
    </DataTemplate>

    <DataTemplate DataType="vm:AsaLauncherSettingsSectionScreenViewModel">
      <StackPanel Spacing="16">
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1">
          <StackPanel Spacing="8">
            <TextBlock Text="ASA settings" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Text="{u:Tr mainWindow.linuxCompatibilityTool}" FontWeight="SemiBold" />
            <ComboBox ItemsSource="{Binding LinuxLaunchTools}" SelectedIndex="{Binding SelectedAsaLinuxLaunchToolIndex, Mode=TwoWay}" SelectionChanged="AsaLinuxLaunchToolChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate DataType="p:LinuxLaunchToolOption">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <WrapPanel>
              <Button Content="{u:Tr mainWindow.importProtonPath}" Click="ImportAsaLinuxProtonTool" />
              <Button Margin="10,0,0,0" Content="{u:Tr mainWindow.importWinePath}" Click="ImportAsaLinuxWineTool" />
            </WrapPanel>
            <TextBlock Text="{Binding LinuxLaunchToolNote}" TextWrapping="Wrap" Foreground="#A7C4E3" />
          </StackPanel>
        </Border>

        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1">
          <StackPanel Spacing="8">
            <TextBlock Text="{u:Tr mainWindow.customPrefix}" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,Auto">
              <TextBox Text="{Binding AsaLinuxCustomPrefixPath, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="{u:Tr mainWindow.placeholderCustomPrefix}" />
              <Button Grid.Column="1" Margin="12,0,0,0" Content="{u:Tr mainWindow.browse}" Click="BrowseAsaLinuxCompatPrefix" />
            </Grid>
            <TextBlock Text="{u:Tr mainWindow.customPrefixDescription}" Opacity="0.78" TextWrapping="Wrap" />

            <WrapPanel Margin="0,8,0,0">
              <CheckBox Content="{u:Tr mainWindow.gamemoderun}" IsChecked="{Binding AsaLinuxUseGameMode}" />
              <CheckBox Margin="14,0,0,0" Content="{u:Tr mainWindow.gamescope}" IsChecked="{Binding AsaLinuxUseGamescope}" />
              <CheckBox Margin="14,0,0,0" Content="{u:Tr mainWindow.mangohud}" IsChecked="{Binding AsaLinuxUseMangoHud}" />
              <CheckBox Margin="14,0,0,0" Content="{u:Tr mainWindow.vkbasalt}" IsChecked="{Binding AsaLinuxUseVkBasalt}" />
              <CheckBox Margin="14,0,0,0" Content="{u:Tr mainWindow.wineFsr}" IsChecked="{Binding AsaLinuxUseWineFullscreenFsr}" />
            </WrapPanel>

            <StackPanel Spacing="6" IsVisible="{Binding AsaLinuxGamescopeOptionsVisible}">
              <TextBlock Text="{u:Tr mainWindow.gamescopeArguments}" FontWeight="SemiBold" />
              <TextBox Text="{Binding AsaLinuxGamescopeArguments, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="{u:Tr mainWindow.placeholderGamescopeArgs}" />
              <CheckBox Content="{u:Tr mainWindow.enableGamescopeFsr}" IsChecked="{Binding AsaLinuxUseGamescopeFsr}" />
              <TextBox Text="{Binding AsaLinuxGamescopeSharpness, UpdateSourceTrigger=PropertyChanged}" IsVisible="{Binding AsaLinuxGamescopeFsrOptionsVisible}" PlaceholderText="{u:Tr mainWindow.gamescopeFsrSharpness}" />
            </StackPanel>

            <StackPanel Spacing="6" IsVisible="{Binding AsaLinuxWineFsrOptionsVisible}">
              <TextBlock Text="{u:Tr mainWindow.wineFsrStrength}" FontWeight="SemiBold" />
              <TextBox Text="{Binding AsaLinuxWineFullscreenFsrStrength, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="{u:Tr mainWindow.placeholderWineFsrStrength}" />
            </StackPanel>

            <TextBlock Margin="0,8,0,0" Text="{u:Tr mainWindow.extraEnvVars}" FontWeight="SemiBold" />
            <TextBox Text="{Binding AsaLinuxExtraEnvironmentVariables, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90" PlaceholderText="{u:Tr mainWindow.placeholderExtraEnv}" />

            <TextBlock Margin="0,8,0,0" Text="{u:Tr mainWindow.launchWrappers}" FontWeight="SemiBold" />
            <TextBox Text="{Binding AsaLinuxLaunchWrappers, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90" PlaceholderText="{u:Tr mainWindow.placeholderLaunchWrappers}" />
          </StackPanel>
        </Border>
      </StackPanel>
    </DataTemplate>
    <DataTemplate DataType="vm:ServersSectionScreenViewModel">
      <StackPanel Spacing="16">
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" TextWrapping="Wrap" />
            <Button Grid.Column="1" Margin="12,0,0,0" Content="{u:Tr mainWindow.refresh}" Click="RefreshServers" />
          </Grid>
        </Border>
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1" IsVisible="{Binding IsRefreshing}">
          <StackPanel Spacing="8" HorizontalAlignment="Center">
            <v:LoadingSpinner />
            <TextBlock Text="{u:Tr mainWindow.refreshingClusters}" HorizontalAlignment="Center" />
          </StackPanel>
        </Border>
        <ItemsControl ItemsSource="{Binding Rows}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:ServersClusterRowViewModel">
              <Button Padding="0" Background="Transparent" BorderThickness="0" Click="SelectServersCluster" Margin="0,0,8,8">
                <Button.DataContext>
                  <Binding />
                </Button.DataContext>
                <Border Padding="12,6" CornerRadius="999" BorderThickness="1" Classes.selected="{Binding IsSelected}">
                  <Border.Styles>
                    <Style Selector="Border">
                      <Setter Property="Background" Value="#172A3C"/>
                      <Setter Property="BorderBrush" Value="#2E4F6D"/>
                      <Setter Property="Transitions">
                        <Transitions>
                          <BrushTransition Property="Background" Duration="0:0:0.15"/>
                          <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                        </Transitions>
                      </Setter>
                    </Style>
                    <Style Selector="Border:pointerover">
                      <Setter Property="Background" Value="#233E59"/>
                      <Setter Property="BorderBrush" Value="#3F6A93"/>
                    </Style>
                    <Style Selector="Border.selected">
                      <Setter Property="Background" Value="#2B5D8C"/>
                      <Setter Property="BorderBrush" Value="#4C8CC7"/>
                    </Style>
                    <Style Selector="Border.selected:pointerover">
                      <Setter Property="Background" Value="#346FA6"/>
                      <Setter Property="BorderBrush" Value="#5BA2E3"/>
                    </Style>
                  </Border.Styles>
                  <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                    <Border Padding="6,2" CornerRadius="999" Background="#0C1A2C" VerticalAlignment="Center" MinWidth="18">
                      <TextBlock Text="{Binding ServerCount}" FontSize="11" FontWeight="Bold" Foreground="#8EB2D4" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                  </StackPanel>
                </Border>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Border Padding="16" CornerRadius="12" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1" IsVisible="{Binding SelectedCluster}">
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel>
                <TextBlock Text="{Binding SelectedCluster.Name}" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="{Binding SelectedCluster.Detail}" Opacity="0.74" />
                <TextBlock Text="{Binding SelectedCluster.HosterText}" Opacity="0.82" IsVisible="{Binding SelectedCluster.HasHoster}" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Content="{u:Tr mainWindow.discord}" Click="OpenClusterDiscord" IsVisible="{Binding SelectedCluster.HasDiscord}" />
                <Button Content="{u:Tr mainWindow.refresh}" Click="RefreshSelectedServersCluster" IsVisible="{Binding SelectedCluster.CanRefresh}" />
              </StackPanel>
            </Grid>
            <Border Padding="12" CornerRadius="10" Background="#132132" BorderBrush="#2A4C6D" BorderThickness="1" IsVisible="{Binding SelectedCluster.HasDescription}">
              <StackPanel Spacing="8">
                <TextBlock Text="{u:Tr common.description}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding SelectedCluster.DescriptionText}" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <ItemsControl ItemsSource="{Binding SelectedClusterServers}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:ServerRowViewModel">
                  <Border Padding="14" CornerRadius="12" Background="#132132" BorderBrush="#2A4C6D" BorderThickness="1">
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                      <StackPanel>
                        <TextBlock Text="{Binding DisplayName}" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock>
                          <Run Text="{Binding DisplayMapName}" />
                          <Run Text=" | " />
                          <Run Text="{Binding ModeText}" Foreground="{Binding ModeColor}" />
                          <Run Text=" | " />
                          <Run Text="{Binding Version}" />
                          <Run Text=" | " />
                          <Run Text="{Binding NumPlayers}" />
                          <Run Text="/" />
                          <Run Text="{Binding MaxNumPlayers}" />
                        </TextBlock>
                        <TextBlock Text="{Binding Address}" Opacity="0.72" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Margin="12,0,0,0" Orientation="Horizontal" Spacing="8">
                        <Button Content="{u:Tr serversTab.join}" Click="JoinSelectedServer" />
                        <Button Content="{u:Tr serversTab.favorites}" Click="ToggleFavoriteServer" />
                        <Button Content="{u:Tr mainWindow.discord}" Click="OpenServerDiscord" IsVisible="{Binding HasDiscord}" />
                      </StackPanel>
                      <Expander Grid.Row="1" Grid.ColumnSpan="2" Margin="0,12,0,0" Header="{u:Tr common.details}" Expanded="ExpandServerDetails" IsVisible="{Binding CanShowDetails}">
                        <StackPanel Margin="0,12,0,0" Spacing="10">
                          <TextBlock Text="{Binding HosterText}" IsVisible="{Binding HasHoster}" />
                          <Border Padding="12" CornerRadius="10" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1" IsVisible="{Binding HasDescription}">
                            <StackPanel Spacing="8">
                              <TextBlock Text="{u:Tr common.description}" FontWeight="SemiBold" />
                              <TextBlock Text="{Binding DescriptionText}" TextWrapping="Wrap" />
                            </StackPanel>
                          </Border>
                          <Border Padding="12" CornerRadius="10" Background="#0C1A2C" BorderBrush="#274665" BorderThickness="1" IsVisible="{Binding HasMods}">
                            <StackPanel Spacing="10">
                              <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{u:Tr tabs.mods}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="{u:Tr gameOptionsTab.validateAll}" Click="ValidateAllServerMods" />
                              </Grid>
                              <StackPanel Spacing="8" IsVisible="{Binding IsLoadingModDetails}" Orientation="Horizontal">
                                <v:LoadingSpinner Width="20" Height="20" />
                                <TextBlock Text="{u:Tr common.loading}" Opacity="0.74" VerticalAlignment="Center" />
                              </StackPanel>
                              <ItemsControl ItemsSource="{Binding ModRows}" IsVisible="{Binding HasModRows}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate DataType="vm:ServerModRowViewModel">
                                    <Border Padding="10" CornerRadius="8" Background="#132132" BorderBrush="#2A4C6D" BorderThickness="1">
                                      <Grid ColumnDefinitions="*,Auto,Auto">
                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        <Button Grid.Column="1" Margin="8,0,0,0" Content="{u:Tr mainWindow.install}" Click="InstallServerMod" IsVisible="{Binding CanInstall}" />
                                        <TextBlock Grid.Column="1" Margin="8,0,0,0" Text="{u:Tr common.installed}" VerticalAlignment="Center" IsVisible="{Binding IsInstalled}" />
                                        <Button Grid.Column="2" Margin="8,0,0,0" Content="{u:Tr mainWindow.workshop}" Click="OpenServerModWorkshopPage" />
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>
                        </StackPanel>
                      </Expander>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </StackPanel>
    </DataTemplate>
  </Window.DataTemplates>
  <Grid ColumnDefinitions="280,*" Margin="20">
    <Border Padding="20"
            CornerRadius="18,0,0,18"
            Background="#17202C"
            BorderBrush="#284560"
            BorderThickness="1,1,0,1">
      <Grid RowDefinitions="Auto,*">
        <StackPanel Spacing="12">
          <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="SemiBold" />
          <TextBlock Text="{Binding Subtitle}" Opacity="0.78" TextWrapping="Wrap" />
        </StackPanel>
        <ScrollViewer Grid.Row="1" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding NavigationGroups}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:LauncherNavGroupViewModel">
                <Border Margin="0,0,0,12"
                        Padding="14"
                        CornerRadius="14"
                        Background="#132132"
                        BorderBrush="#22384E"
                        BorderThickness="1">
                  <StackPanel IsVisible="{Binding IsVisible}" Spacing="10">
                    <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" Opacity="0.9" />
                    <Grid ColumnDefinitions="4,*">
                      <Border Background="#2E5E8C" CornerRadius="2" Margin="0,2,10,2" />
                      <ItemsControl Grid.Column="1" ItemsSource="{Binding Children}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate DataType="vm:LauncherNavNodeViewModel">
                            <Button Padding="12,8"
                                    Background="#17202C"
                                    BorderBrush="#2A4C6D"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    HorizontalContentAlignment="Left"
                                    Click="SelectNavigationNode"
                                    Classes.selected="{Binding IsSelected}">
                              <Button.Styles>
                                <Style Selector="Button.selected">
                                  <Setter Property="Background" Value="#2B5D8C" />
                                  <Setter Property="BorderBrush" Value="#4C8CC7" />
                                </Style>
                              </Button.Styles>
                              <TextBlock Text="{Binding Title}" />
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Grid>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>
    <Border Grid.Column="1"
            Padding="24"
            CornerRadius="0,18,18,0"
            Background="#10233A"
            BorderBrush="#2E5E8C"
            BorderThickness="0,1,1,1">
      <Grid RowDefinitions="Auto,*">
        <StackPanel Spacing="16">
          <TextBlock Text="{Binding SelectedSectionTitle}" FontSize="30" FontWeight="SemiBold" />
          <TextBlock Text="{Binding SelectedSectionDescription}" Opacity="0.78" TextWrapping="Wrap" />
          <Border Padding="16"
                  CornerRadius="12"
                  Background="#0C1A2C"
                  BorderBrush="#274665"
                  BorderThickness="1">
            <Grid ColumnDefinitions="Auto,*">
              <TextBlock Text="{u:Tr playTab.gameVersion}" FontSize="14" Opacity="0.72" />
              <TextBlock Grid.Column="1" Margin="12,0,0,0" Text="{Binding GameVersion}" Foreground="{Binding GameVersionColor}" FontSize="16" FontWeight="SemiBold" />
            </Grid>
          </Border>
          <Border Padding="16"
                  CornerRadius="12"
                  Background="#0C1A2C"
                  BorderBrush="#274665"
                  BorderThickness="1"
                  IsVisible="{Binding IsBusy}">
            <StackPanel Spacing="8">
              <StackPanel Spacing="8" HorizontalAlignment="Center">
                <v:LoadingSpinner />
                <TextBlock Text="{u:Tr common.loading}" HorizontalAlignment="Center" />
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
        <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="16">
            <ItemsControl ItemsSource="{Binding Notices}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:ShellNoticeViewModel">
                  <Border Padding="14,10"
                          CornerRadius="12"
                          Background="#2A1F11"
                          BorderBrush="#B98532"
                          BorderThickness="1">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="{Binding Message}" TextWrapping="Wrap" VerticalAlignment="Center" />
                      <Button Grid.Column="1"
                              Margin="12,0,0,0"
                              Content="{Binding ActionLabel}"
                              Click="NoticeActionClick"
                              IsVisible="{Binding HasAction}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <ContentControl Content="{Binding CurrentScreen}" />
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Border>
  </Grid>
</Window>