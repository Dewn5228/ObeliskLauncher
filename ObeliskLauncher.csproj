<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Platform>x64</Platform>
    <OutputType>WinExe</OutputType>
    <Version>1.2.10</Version>
    <Authors>Nuclearist, Dewn</Authors>
    <Product>Obelisk Launcher</Product>
    <Copyright>Copyright © 2020-2026 Nuclearist, Dewn</Copyright>
    <AppendTargetFrameworkToOutputPath>False</AppendTargetFrameworkToOutputPath>
    <AppendRuntimeIdentifierToOutputPath>False</AppendRuntimeIdentifierToOutputPath>
    <Nullable>Enable</Nullable>
    <AllowUnsafeBlocks>True</AllowUnsafeBlocks>
    <DefineConstants>$(DefineConstants);UI_AVALONIA</DefineConstants>
    <ApplicationIcon Condition="Exists('assets/icon.ico')">assets\icon.ico</ApplicationIcon>
  </PropertyGroup>
  <PropertyGroup>
    <ProtoRoot>$(ProjectDir)protos/</ProtoRoot>
    <ProtoOutputDir>$(ProjectDir)src/</ProtoOutputDir>
    <ProtocExecutable Condition="$([MSBuild]::IsOSPlatform('Windows'))">$(NuGetPackageRoot)google.protobuf.tools/3.35.0/tools/windows_x64/protoc.exe</ProtocExecutable>
    <ProtocExecutable Condition="$([MSBuild]::IsOSPlatform('Linux'))">$(NuGetPackageRoot)google.protobuf.tools/3.35.0/tools/linux_x64/protoc</ProtocExecutable>
    <ProtocExecutable Condition="$([MSBuild]::IsOSPlatform('OSX'))">$(NuGetPackageRoot)google.protobuf.tools/3.35.0/tools/macosx_x64/protoc</ProtocExecutable>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <Optimize>True</Optimize>
    <SignAssembly>True</SignAssembly>
    <AssemblyOriginatorKeyFile>SigningKey.snk</AssemblyOriginatorKeyFile>
    <DelaySign>False</DelaySign>
    <PublishSingleFile>True</PublishSingleFile>
    <SelfContained>False</SelfContained>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="CommunityToolkit.HighPerformance" Version="8.4.2" />
    <PackageReference Include="Google.Protobuf" Version="3.35.0" />
    <PackageReference Include="Google.Protobuf.Tools" Version="3.35.0" />
    <PackageReference Include="Avalonia" Version="12.0.3" />
    <PackageReference Include="Avalonia.Desktop" Version="12.0.3" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="12.0.3" />
    <PackageReference Include="Serilog" Version="4.3.1" />
    <PackageReference Include="Serilog.Sinks.Console" Version="6.1.1" />
    <PackageReference Include="Serilog.Sinks.File" Version="7.0.0" />
  </ItemGroup>
  <ItemGroup>
    <AvaloniaResource Include="res\**" Condition="Exists('res')" />
    <AvaloniaResource Include="locales\**" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="assets\catalog\game-catalog.json" Condition="Exists('assets\catalog\game-catalog.json')" />
  </ItemGroup>
  <ItemGroup>
    <Protos Include="protos\**" />
  </ItemGroup>
  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>ObeliskLauncher.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="ObeliskLauncher.Tests\**" />
    <Compile Remove="src\Steam\CM\Messages\**\*.g.cs" />
    <EmbeddedResource Remove="ObeliskLauncher.Tests\**" />
    <None Remove="ObeliskLauncher.Tests\**" />
  </ItemGroup>
  <Target Name="GenerateProtobufSources" BeforeTargets="CoreCompile">
    <Exec Command="$(ProtocExecutable) --proto_path=$(ProtoRoot) --csharp_out=$(ProtoOutputDir) --csharp_opt=file_extension=.g.cs --csharp_opt=base_namespace=ObeliskLauncher %(Protos.Identity)" />
    <ItemGroup>
      <Compile Include="src\Steam\CM\Messages\**\*.g.cs" />
    </ItemGroup>
  </Target>
</Project>